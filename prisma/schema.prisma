generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model UserProfile {
  id         Int      @id @default(1)
  gender     String   // "male" | "female"
  birthday   String?  // YYYY-MM-DD
  height     Float    // cm
  goalWeight Float?   // kg
  goalDays   Int?     // target days to reach goal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  weight    Float    // kg
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
}

model FoodItem {
  id             Int         @id @default(autoincrement())
  name           String
  category       String?     // 碳水 | 蛋白质 | 脂肪 | 蔬菜 | 水果 | 乳制品 | 饮料 | 零食 | 其他
  servingUnit    String
  servingAmount  Float
  kcalPerServing Float
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  mealEntries    MealEntry[]

  @@index([name])
  @@index([category])
}

model MealEntry {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  mealType  String   // "breakfast" | "lunch" | "dinner" | "snack"
  foodId    Int
  food      FoodItem @relation(fields: [foodId], references: [id])
  quantity  Float
  kcal      Float    // snapshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model DailyActivity {
  id           Int      @id @default(autoincrement())
  date         String   // YYYY-MM-DD
  exerciseKcal Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date])
}
